# Backend
DATABASE_URL=sqlite:///./rolefit.db
CORS_ORIGINS=http://localhost:3000
APP_ENV=development

# Real AI provider configuration
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Real speech transcription provider configuration
SPEECH_PROVIDER=deepgram
SPEECH_MODEL=nova-3
DEEPGRAM_API_KEY=

# Future provider placeholders
AWS_REGION=ap-south-1
AZURE_SPEECH_REGION=centralindia
# AZURE_SPEECH_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=/secure/path/service-account.json

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
